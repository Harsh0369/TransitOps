generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum ComplianceType {
  INSURANCE
  PUC
  FITNESS
  REGISTRATION
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  PENDING_APPROVAL
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phoneNumber String?  @unique
  password    String
  role        Role       @default(FLEET_MANAGER)
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  drivers   Driver[]
  trips     Trip[]     @relation("UserTrips")
  auditLogs AuditLog[]
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique
  name               String
  model              String
  type               String
  capacity           Float
  odometer           Float         @default(0)
  acquisitionCost    Float
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  trips         Trip[]
  maintenance   Maintenance[]
  fuelLogs      FuelLog[]
  expenses      Expense[]
  statusHistory VehicleStatusHistory[]
  compliances   VehicleCompliance[]
}

model Driver {
  id              String       @id @default(uuid())
  userId          String?      @unique
  name            String
  licenseNumber   String       @unique
  licenseCategory String
  licenseExpiry   DateTime
  contactNumber   String
  safetyScore     Float        @default(100.0)
  profilePictureUrl String?
  status          DriverStatus @default(AVAILABLE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  user  User?  @relation(fields: [userId], references: [id])
  trips Trip[]
}

model Trip {
  id              String     @id @default(uuid())
  source          String
  destination     String
  driverId        String
  vehicleId       String
  userId          String
  cargoWeight     Float
  distance        Float?
  dispatchDate    DateTime?
  completionDate  DateTime?
  completionNotes String?
  finalOdometer   Float?
  fuelUsed        Float?
  status          TripStatus @default(DRAFT)
  rejectionReason String?
  rejectedBy      String?
  rejectedAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  driver            Driver              @relation(fields: [driverId], references: [id])
  vehicle           Vehicle             @relation(fields: [vehicleId], references: [id])
  user              User                @relation("UserTrips", fields: [userId], references: [id])
  fuelLog           FuelLog?            // One-to-one relationship
  statusHistory     TripStatusHistory[]
}

model Maintenance {
  id              String            @id @default(uuid())
  vehicleId       String
  maintenanceType String
  description     String
  status          MaintenanceStatus @default(OPEN)
  cost            Float?
  startDate       DateTime          @default(now())
  endDate         DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  tripId    String?  @unique
  liters    Float
  cost      Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  vehicleId   String
  expenseType String
  amount      Float
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model TripStatusHistory {
  id             String     @id @default(uuid())
  tripId         String
  previousStatus TripStatus?
  status         TripStatus
  changedBy      String?
  remarks        String?
  timestamp      DateTime   @default(now())

  trip Trip @relation(fields: [tripId], references: [id])
}

model VehicleStatusHistory {
  id        String        @id @default(uuid())
  vehicleId String
  oldStatus VehicleStatus?
  newStatus VehicleStatus
  changedBy String?
  remarks   String?
  changedAt DateTime      @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model VehicleCompliance {
  id                String         @id @default(uuid())
  vehicleId         String
  type              ComplianceType
  certificateNumber String
  issueDate         DateTime
  expiryDate        DateTime
  documentUrl       String?
  remarks           String?
  createdBy         String?
  updatedBy         String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@unique([vehicleId, type])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  oldValue  Json?
  newValue  Json?
  metadata  Json?
  reason    String?
  ipAddress String?
  userId    String?
  timestamp DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
